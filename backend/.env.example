APP_NAME=Document Processing Workflow API
DEBUG=true
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000
# Optional regex for dynamic frontend hostnames (example Render subdomains)
# CORS_ORIGIN_REGEX=^https://.*\.onrender\.com$
ALLOWED_HOSTS=localhost,127.0.0.1
ENFORCE_HTTPS=false
GZIP_MINIMUM_SIZE=1024

DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/docproc
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
REDIS_PROGRESS_CHANNEL=job_progress
# For hosted Redis with TLS (rediss://), set required|optional|none.
REDIS_SSL_CERT_REQS=required
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true

UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
