# Domain used by Caddy for automatic HTTPS
DOMAIN=example.com

# Backend app settings
APP_NAME=async-document-processing-workflow
DEBUG=false
API_PREFIX=/api
CORS_ORIGINS=https://example.com

# Database and Redis credentials
POSTGRES_DB=docproc
POSTGRES_USER=docproc
POSTGRES_PASSWORD=change-this-password

# Service connection URLs
DATABASE_URL=postgresql+psycopg://docproc:change-this-password@postgres:5432/docproc
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
REDIS_PROGRESS_CHANNEL=job_progress

# Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=20

# Frontend config (same-origin through Caddy)
NEXT_PUBLIC_API_BASE_URL=/api
